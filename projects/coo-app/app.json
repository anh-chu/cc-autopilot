{
  "expo": {
    "name": "Coo",
    "slug": "coo-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "coo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0D2B2E",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.coo.feedingapp",
      "backgroundColor": "#0D2B2E"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D2B2E"
      },
      "package": "com.coo.feedingapp"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ]
  }
}
