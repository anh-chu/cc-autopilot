      "name": "dads-day-out",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('http'),f=require('fs'),p=require('path'),m={'.html':'text/html','.js':'application/javascript','.css':'text/css','.json':'application/json','.png':'image/png','.jpg':'image/jpeg','.wav':'audio/wav','.mp3':'audio/mpeg','.ogg':'audio/ogg'};h.createServer((q,r)=>{let u=q.url==='/'?'/index.html':q.url;let fp=p.join(__dirname,u);f.readFile(fp,(e,d)=>{if(e){r.writeHead(404);r.end('Not found');return}r.writeHead(200,{'Content-Type':m[p.extname(fp)]||'application/octet-stream'});r.end(d)})}).listen(8888,()=>console.log('Serving on http://localhost:8888'))"],
      "port": 8888,
      "cwd": "projects/dads-day-out"
    },
